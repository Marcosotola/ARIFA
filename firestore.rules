rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES CENTRALES ---
    
    function getRole() {
      let userPath = /databases/$(database)/documents/usuarios/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.rol : 'cliente';
    }
    
    function isAdmin() {
      return request.auth != null && getRole() in ['admin', 'superadmin'];
    }
    
    function isStaffMember() {
      return request.auth != null && getRole() in ['admin', 'superadmin', 'tecnico', 'secretaria', 'supervisor', 'tecnicoHyS'];
    }

    // --- REGLAS DE COLECCIONES ---

    // Usuarios
    match /usuarios/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isStaffMember());
      allow write: if request.auth != null && (isStaffMember() || request.auth.uid == userId);
      allow delete: if isAdmin() || getRole() in ['tecnico', 'secretaria'];
    }

    // Plantillas base
    match /plantillas_inspeccion/{id} {
      allow read: if request.auth != null;
      allow write: if isStaffMember();
    }

    // Plantillas de cliente
    match /plantillas_cliente/{id} {
      allow read: if request.auth != null && isStaffMember();
      allow write: if request.auth != null && isStaffMember();
    }

    // Órdenes de Trabajo (OT)
    match /ordenes_trabajo/{otId} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow write: if request.auth != null && isStaffMember();
      allow delete: if isStaffMember();
    }

    // Matafuegos (Remitos y Fichas)
    match /remitos_matafuegos/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow create, update, delete: if request.auth != null && isStaffMember();
    }
    
    match /mantenimiento_matafuegos/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow create, update, delete: if request.auth != null && isStaffMember();
    }

    // NUEVO: Gestión de Activos y Obleas
    match /configuracion/matafuegos {
      allow read: if request.auth != null;
      allow write: if isStaffMember();
    }

    match /matafuegos_activos/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow create, update, delete: if isStaffMember();
    }

    // Higiene y Seguridad (HyS)
    match /hys_documentos/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow write: if request.auth != null && (isAdmin() || getRole() in ['tecnico', 'supervisor', 'tecnicoHyS']);
    }

    // Plan de Acción
    match /plan_accion/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow write: if request.auth != null && (isAdmin() || getRole() == 'secretaria');
    }

    // Certificados
    match /certificados/{id} {
      allow read: if request.auth != null && (resource.data.clienteId == request.auth.uid || isStaffMember());
      allow write: if isAdmin() || getRole() == 'supervisor';
    }

    // Textos de Memoria Descriptiva
    match /textos_memoria/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Certificadores (responsables de certificado)
    match /certificadores/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Configuración y Suscripciones
    match /configuracion/suscripcion {
      allow read: if true;
      allow write: if request.auth != null && getRole() == 'superadmin';
    }

    // Productos
    match /productos/{prodId} {
      allow read: if true;
      allow write: if isStaffMember();
    }

    // Presupuestos
    match /presupuestos/{id} {
      allow read: if request.auth != null && (
        resource.data.clienteId == request.auth.uid || isStaffMember()
      );
      allow create: if request.auth != null && isStaffMember();
      allow update: if request.auth != null && isStaffMember();
      allow delete: if isAdmin();
    }

    match /configuracion/presupuestos {
      allow read: if request.auth != null && isStaffMember();
      allow write: if request.auth != null && isStaffMember();
    }

    // Recibos
    match /recibos/{id} {
      allow read: if request.auth != null && (
        resource.data.clienteId == request.auth.uid || isStaffMember()
      );
      allow create: if request.auth != null && isStaffMember();
      allow update: if request.auth != null && isStaffMember();
      allow delete: if isAdmin();
    }

    match /configuracion/recibos {
      allow read: if request.auth != null && isStaffMember();
      allow write: if request.auth != null && isStaffMember();
    }

    // Remitos de Entrega
    match /remitos_doc/{id} {
      allow read: if request.auth != null && (
        resource.data.clienteId == request.auth.uid || isStaffMember()
      );
      allow create: if request.auth != null && isStaffMember();
      allow update: if request.auth != null && isStaffMember();
      allow delete: if isAdmin();
    }

    match /configuracion/remitos_doc {
      allow read, write: if request.auth != null && isStaffMember();
    }

    // Estados de Cuenta
    match /estados-cuenta/{id} {
      allow read: if request.auth != null && (isStaffMember() || resource.data.clienteId == request.auth.uid);
      allow create, update: if request.auth != null && isStaffMember();
      allow delete: if isAdmin();
    }

    match /configuracion/estados-cuenta {
      allow read, write: if request.auth != null && isStaffMember();
    }

    // Consultas y Notificaciones
    match /consultas/{id} {
      allow read: if request.auth != null && (isAdmin() || getRole() == 'secretaria');
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /notificaciones_enviadas/{id} {
      allow read: if request.auth != null && (isStaffMember() || resource.data.destinatarioUid == request.auth.uid);
      allow write: if isStaffMember();
    }

    // Pagos de suscripción
    match /pagos_suscripcion/{id} {
      allow read, write: if request.auth != null && getRole() == 'superadmin';
    }
  }
}
